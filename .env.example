# Root-level server environment example
# The backend loads this file automatically when present.

MONGODB_URI=mongodb://localhost:27017/vendor_po_manager
JWT_SECRET=change-me-before-production
PORT=5000
NODE_ENV=development
ALLOW_PUBLIC_REGISTRATION=true
FRONTEND_URL=http://localhost:5173

# Optional first admin bootstrap. Useful on deployed databases where seed.js has not been run.
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@vendor.com
ADMIN_PASSWORD=admin123

# Optional email delivery settings
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Vendor & PO Manager" <noreply@example.com>

# Optional Google OAuth server credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Frontend Vite variables belong in client/.env
